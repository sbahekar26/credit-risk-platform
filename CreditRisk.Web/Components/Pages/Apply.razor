@page "/apply"
@rendermode InteractiveServer
@using CreditRisk.Core

<h3>Loan Application</h3>

<EditForm Model="@application" OnValidSubmit="@SubmitApplication" FormName="loanForm">
    <div>
        <label>Full Name:</label>
        <InputText @bind-Value="application.FullName" />
    </div>
    <div>
        <label>Age:</label>
        <InputNumber @bind-Value="application.Age" />
    </div>
    <div>
        <label>Checking Account Status:</label>
        <InputSelect @bind-Value="application.CheckingStatus">
            <option value="A11">Negative balance (&lt; 0 DM)</option>
            <option value="A12">0 – 200 DM</option>
            <option value="A13">200+ DM</option>
            <option value="A14">No checking account</option>
        </InputSelect>
    </div>
    <div>
        <label>Loan Duration (months):</label>
        <InputNumber @bind-Value="application.DurationMonths" />
    </div>
    <div>
        <label>Credit History:</label>
        <InputSelect @bind-Value="application.CreditHistory">
            <option value="A30">No credits taken</option>
            <option value="A31">All paid back duly</option>
            <option value="A32">Existing credits paid duly</option>
            <option value="A33">Past payment delays</option>
            <option value="A34">Critical account</option>
        </InputSelect>
    </div>
    <div>
        <label>Purpose:</label>
        <InputSelect @bind-Value="application.Purpose">
            <option value="A40">Car (new)</option>
            <option value="A41">Car (used)</option>
            <option value="A42">Furniture/equipment</option>
            <option value="A43">Radio/TV</option>
            <option value="A46">Education</option>
            <option value="A49">Business</option>
        </InputSelect>
    </div>
    <div>
        <label>Credit Amount:</label>
        <InputNumber @bind-Value="application.CreditAmount" />
    </div>
    <div>
        <label>Savings:</label>
        <InputSelect @bind-Value="application.Savings">
            <option value="A61">&lt; 100 DM</option>
            <option value="A62">100 – 500 DM</option>
            <option value="A63">500 – 1000 DM</option>
            <option value="A64">1000+ DM</option>
            <option value="A65">Unknown / none</option>
        </InputSelect>
    </div>
    <div>
        <label>Employment Duration:</label>
        <InputSelect @bind-Value="application.Employment">
            <option value="A71">Unemployed</option>
            <option value="A72">&lt; 1 year</option>
            <option value="A73">1 – 4 years</option>
            <option value="A74">4 – 7 years</option>
            <option value="A75">7+ years</option>
        </InputSelect>
    </div>
    <div>
        <label>Housing:</label>
        <InputSelect @bind-Value="application.Housing">
            <option value="A151">Rent</option>
            <option value="A152">Own</option>
            <option value="A153">For free</option>
        </InputSelect>
    </div>

    <button type="submit">Submit Application</button>
</EditForm>

@if (decision != null)
{
    <h4>Decision: @decision</h4>
}

@code {
    private LoanApplication application = new LoanApplication
    {
        FullName = "",
        CheckingStatus = "A11",
        CreditHistory = "A30",
        Purpose = "A40",
        Savings = "A61",
        Employment = "A71",
        Housing = "A151",
        SubmittedOn = DateTime.Now
    };

    private string? decision;

    private void SubmitApplication()
    {
        // placeholder — will call the API/model next
        decision = "Submitted (scoring coming next)";
    }
}