@page "/apply"
@rendermode InteractiveServer
@using CreditRisk
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<h3>Loan Application</h3>

<EditForm Model="@application" OnValidSubmit="@SubmitApplication" FormName="loanForm">
    <div>
        <label>Full Name:</label>
        <InputText @bind-Value="application.Applicant.FullName" />
    </div>
    <div>
        <label>Age:</label>
        <InputNumber @bind-Value="application.Applicant.Age" />
    </div>
    <div>
        <label>Annual Income:</label>
        <InputNumber @bind-Value="application.Applicant.AnnualIncome" />
    </div>
    <div>
        <label>Credit Score:</label>
        <InputNumber @bind-Value="application.Applicant.CreditScore" />
    </div>
    <div>
        <label>Loan Amount:</label>
        <InputNumber @bind-Value="application.LoanAmount" />
    </div>
    <div>
        <label>Purpose:</label>
        <InputText @bind-Value="application.Purpose" />
    </div>

    <button type="submit">Submit Application</button>
</EditForm>

@if (decision != null)
{
    <h4>Decision: @decision</h4>
}

@code {
    private LoanApplication application = new LoanApplication
    {
        Applicant = new Applicant { FullName = "" },
        Purpose = "",
        SubmittedOn = DateTime.Now
    };

    private string? decision;

    private async Task SubmitApplication()
    {
        var client = HttpClientFactory.CreateClient();

        var response = await client.PostAsJsonAsync(
            "http://localhost:5260/api/applications", application);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<DecisionResponse>();
            decision = result?.Decision;
        }
        else
        {
            decision = "Error contacting the service";
        }
    }

    private class DecisionResponse
    {
        public int ApplicationId { get; set; }
        public string? Applicant { get; set; }
        public string? Decision { get; set; }
    }
}